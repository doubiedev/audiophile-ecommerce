{
    "name": "audiophile-ecommerce",
    "version": "1.0.0",
    "description": "",
    "scripts": {
        "server": "tsx --watch --env-file .env src/server.ts",
        "client": "npm run dev --prefix frontend",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "start": "node --env-file .env dist/server.js",
        "build": "tsc -p tsconfig.build.json",
        "db": "docker compose -f docker/compose.yml up -d",
        "db:stop": "docker compose -f docker/compose.yml down",
        "test": "vitest",
        "test:db": "docker compose -f docker/compose.test.yml up -d",
        "test:db:stop": "docker compose -f docker/compose.test.yml down",
        "test:integration": "npm run test:db && vitest --run src/__tests__ && npm run test:db:stop",
        "test:run": "vitest --run",
        "test:ui": "vitest --ui",
        "coverage": "vitest run --coverage",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "imports": {
        "#*": "./src/*"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "eslint",
            "prettier --check"
        ],
        "*.{json,yml,yaml,md}": [
            "prettier --check"
        ]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/doubiedev/audiophile-ecommerce.git"
    },
    "keywords": [],
    "author": "Nicholas Doublet",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/doubiedev/audiophile-ecommerce/issues"
    },
    "homepage": "https://github.com/doubiedev/audiophile-ecommerce#readme",
    "dependencies": {
        "argon2": "^0.44.0",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.3.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "9.39.4",
        "@tsconfig/node24": "^24.0.4",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.5.0",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.0",
        "@vitest/eslint-plugin": "^1.6.12",
        "concurrently": "^9.1.2",
        "eslint": "9.39.4",
        "eslint-plugin-perfectionist": "^5.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vitest": "^4.1.0"
    }
}
